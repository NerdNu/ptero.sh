#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
source "${SCRIPT_DIR}/ptero-common.sh"

usage() {
  cat <<'USAGE'
Usage:
  ./ptero-endpoint-show [--velocity-name <name>] [--target-mode <allocation|docker>] [--target-host <host>] [--target-port <port>] [--check-reachability] [--update-velocity-config] [--dry-run] <server>

Matches <server> against Panel server ID, external ID, UUID, short UUID, or exact name.

By default, the backend target is allocation-first: allocation alias plus port,
then allocation IP plus port. Docker-network IP is used only in
`--target-mode docker` or as a final fallback when allocation data is unusable.

If --check-reachability is set, the command tries to test TCP reachability from the
Velocity container to the resolved backend target. It uses `PTERO_VELOCITY_SERVER`
when set. Otherwise it auto-detects a single Panel server whose name or external
ID contains "velocity".

If --update-velocity-config is set, the command updates the Velocity server's
`velocity.toml` `[servers]` entry for the resolved backend target. It writes to
`$PTERO_VELOCITY_TOML` when set, otherwise to
`$PTERO_VOLUMES_DIR/<velocity-uuid>/velocity.toml`.

Examples:
  ./ptero-endpoint-show 10
  ./ptero-endpoint-show lobby-dev
  ./ptero-endpoint-show "Lobby Dev"
  ./ptero-endpoint-show --velocity-name lobby 10
  ./ptero-endpoint-show --target-mode allocation --velocity-name lobby 10
  ./ptero-endpoint-show --check-reachability --velocity-name lobby 10
  ./ptero-endpoint-show --update-velocity-config --velocity-name lobby 10
  ./ptero-endpoint-show --update-velocity-config --dry-run --velocity-name lobby 10
USAGE
}

require_tools() {
  local missing=0

  for tool in jq; do
    if ! command -v "$tool" >/dev/null 2>&1; then
      printf 'Missing required command: %s\n' "$tool" >&2
      missing=1
    fi
  done

  [[ "$missing" -eq 0 ]] || exit 1
}

run_docker_command() {
  local prompt_message="$1"
  shift
  local output

  if command -v docker >/dev/null 2>&1; then
    if output="$(docker "$@" 2>/dev/null)"; then
      printf '%s\n' "$output"
      return 0
    fi
  fi

  if command -v sudo >/dev/null 2>&1; then
    if output="$(sudo -n docker "$@" 2>/dev/null)"; then
      printf '%s\n' "$output"
      return 0
    fi

    printf '%s\n' "$prompt_message" >&2
    if output="$(sudo docker "$@" 2>/dev/null)"; then
      printf '%s\n' "$output"
      return 0
    fi
  fi

  return 1
}

docker_inspect_json() {
  local container="$1"
  run_docker_command 'Docker inspect requires sudo access; requesting it now.' inspect "$container"
}

docker_exec_capture() {
  local container="$1"
  shift
  run_docker_command 'Docker exec requires sudo access; requesting it now.' exec "$container" "$@"
}

capture_with_timeout() {
  local seconds="$1"
  shift

  if command -v timeout >/dev/null 2>&1; then
    timeout "$seconds" "$@"
    return $?
  fi

  if command -v perl >/dev/null 2>&1; then
    perl -e 'alarm shift @ARGV; exec @ARGV' "$seconds" "$@"
    return $?
  fi

  "$@"
}

velocity_hint_from_networks() {
  local server_key="$1"
  local networks_json="$2"
  local hint_line

  hint_line="$(
    printf '%s\n' "$networks_json" \
      | jq -r --arg server_key "$server_key" '
          to_entries
          | map(select(.value.ip_address != null and .value.ip_address != ""))
          | .[0]?
          | if . == null then
              empty
            else
              "\($server_key) = \"\(.value.ip_address):\(.value.port)\""
            end
        '
  )"

  if [[ -n "$hint_line" ]]; then
    printf '%s\n' "$hint_line"
  fi

  return 0
}

print_backend_target() {
  printf '\nBackend target:\n'
  printf '  Host:            %s\n' "$resolved_target_host"
  printf '  Port:            %s\n' "$resolved_target_port"
  printf '  Source:          %s\n' "$resolved_target_source"
  printf '  Endpoint:        %s:%s\n' "$resolved_target_host" "$resolved_target_port"
}

resolve_backend_target() {
  local allocation_host_candidate="$1"
  local allocation_ip_candidate="$2"
  local allocation_port_candidate="$3"
  local docker_ip_candidate="$4"

  resolved_target_host=""
  resolved_target_port=""
  resolved_target_source=""

  if [[ -n "$target_host_override" ]]; then
    resolved_target_host="$target_host_override"
    if [[ -n "$target_port_override" ]]; then
      resolved_target_port="$target_port_override"
    else
      resolved_target_port="$allocation_port_candidate"
    fi
    resolved_target_source="override"
    return 0
  fi

  if [[ -n "$target_port_override" ]]; then
    resolved_target_port="$target_port_override"
  else
    resolved_target_port="$allocation_port_candidate"
  fi

  if [[ -z "$resolved_target_port" ]]; then
    printf 'Could not resolve a backend target port for %s.\n' "$server_query" >&2
    return 1
  fi

  case "$target_mode" in
    allocation)
      if [[ -n "$allocation_host_candidate" ]]; then
        resolved_target_host="$allocation_host_candidate"
        resolved_target_source="allocation-alias"
        return 0
      fi

      if [[ -n "$allocation_ip_candidate" ]]; then
        resolved_target_host="$allocation_ip_candidate"
        resolved_target_source="allocation-ip"
        return 0
      fi
      ;;

    docker)
      if [[ -n "$docker_ip_candidate" ]]; then
        resolved_target_host="$docker_ip_candidate"
        resolved_target_source="docker-ip"
        return 0
      fi
      ;;
  esac

  if [[ -n "$allocation_ip_candidate" ]]; then
    resolved_target_host="$allocation_ip_candidate"
    resolved_target_source="allocation-ip"
    return 0
  fi

  if [[ -n "$docker_ip_candidate" ]]; then
    resolved_target_host="$docker_ip_candidate"
    resolved_target_source="docker-ip-fallback"
    return 0
  fi

  printf 'Could not resolve a backend target for %s.\n' "$server_query" >&2
  return 1
}

parse_args() {
  velocity_name=""
  target_mode="${PTERO_BACKEND_TARGET_MODE:-allocation}"
  target_host_override="${PTERO_BACKEND_TARGET_HOST:-}"
  target_port_override="${PTERO_BACKEND_TARGET_PORT:-}"
  check_reachability=0
  update_velocity_config=0
  dry_run="${PTERO_DRY_RUN:-0}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --velocity-name)
        [[ $# -ge 2 ]] || {
          printf 'Missing value for --velocity-name\n' >&2
          exit 1
        }
        velocity_name="$2"
        shift 2
        ;;

      --target-mode)
        [[ $# -ge 2 ]] || {
          printf 'Missing value for --target-mode\n' >&2
          exit 1
        }
        target_mode="$2"
        shift 2
        ;;

      --target-host)
        [[ $# -ge 2 ]] || {
          printf 'Missing value for --target-host\n' >&2
          exit 1
        }
        target_host_override="$2"
        shift 2
        ;;

      --target-port)
        [[ $# -ge 2 ]] || {
          printf 'Missing value for --target-port\n' >&2
          exit 1
        }
        target_port_override="$2"
        shift 2
        ;;

      --check-reachability)
        check_reachability=1
        shift
        ;;

      --update-velocity-config)
        update_velocity_config=1
        shift
        ;;

      --dry-run)
        dry_run=1
        shift
        ;;

      -h|--help)
        usage
        exit 0
        ;;

      --)
        shift
        break
        ;;

      -*)
        printf 'Unknown option: %s\n' "$1" >&2
        usage >&2
        exit 1
        ;;

      *)
        break
        ;;
    esac
  done

  [[ $# -eq 1 ]] || {
    usage >&2
    exit 1
  }

  server_query="$1"

  case "$target_mode" in
    allocation|docker)
      ;;
    *)
      printf 'Unsupported target mode: %s\n' "$target_mode" >&2
      exit 1
      ;;
  esac

  if [[ -n "$target_port_override" && ! "$target_port_override" =~ ^[0-9]+$ ]]; then
    printf 'Target port must be numeric: %s\n' "$target_port_override" >&2
    exit 1
  fi
}

validate_server_key() {
  local key="$1"

  if [[ "$key" =~ ^[A-Za-z0-9_-]+$ ]]; then
    return 0
  fi

  printf 'Velocity server key must use only letters, digits, underscores, or hyphens: %s\n' "$key" >&2
  return 1
}

resolve_velocity_toml_path() {
  local velocity_server_json="$1"
  local velocity_uuid

  if [[ -n "${PTERO_VELOCITY_TOML:-}" ]]; then
    printf '%s\n' "$PTERO_VELOCITY_TOML"
    return 0
  fi

  ptero_require_env PTERO_VOLUMES_DIR

  velocity_uuid="$(printf '%s\n' "$velocity_server_json" | jq -r '.uuid')"
  printf '%s/%s/velocity.toml\n' "${PTERO_VOLUMES_DIR%/}" "$velocity_uuid"
}

render_velocity_toml_update() {
  local source_file="$1"
  local output_file="$2"
  local server_key="$3"
  local endpoint="$4"
  local desired_line="${server_key} = \"${endpoint}\""
  local line indent trailing_comment trimmed_line existing_key
  local in_servers_section=0
  local section_found=0
  local entry_found=0

  velocity_update_changed=0
  velocity_update_action=""

  : > "$output_file"

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^[[:space:]]*\[servers\][[:space:]]*$ ]]; then
      section_found=1
      in_servers_section=1
      printf '%s\n' "$line" >> "$output_file"
      continue
    fi

    if [[ "$in_servers_section" -eq 1 && "$line" =~ ^[[:space:]]*\[[^]]+\][[:space:]]*$ ]]; then
      if [[ "$entry_found" -eq 0 ]]; then
        printf '%s\n' "$desired_line" >> "$output_file"
        velocity_update_changed=1
        entry_found=1
      fi

      in_servers_section=0
      printf '%s\n' "$line" >> "$output_file"
      continue
    fi

    if [[ "$in_servers_section" -eq 1 ]]; then
      trimmed_line="${line#"${line%%[![:space:]]*}"}"

      if [[ "$trimmed_line" =~ ^([A-Za-z0-9_-]+)[[:space:]]*= ]]; then
        existing_key="${BASH_REMATCH[1]}"
        if [[ "$existing_key" == "$server_key" ]]; then
          indent=""
          if [[ "$line" =~ ^([[:space:]]*) ]]; then
            indent="${BASH_REMATCH[1]}"
          fi
          trailing_comment=""
          if [[ "$line" =~ ([[:space:]]+#.*)$ ]]; then
            trailing_comment="${BASH_REMATCH[1]}"
          fi

          if [[ "$line" != "${indent}${desired_line}${trailing_comment}" ]]; then
            velocity_update_changed=1
          fi

          printf '%s\n' "${indent}${desired_line}${trailing_comment}" >> "$output_file"
          entry_found=1
          continue
        fi
      fi
    fi

    printf '%s\n' "$line" >> "$output_file"
  done < "$source_file"

  if [[ "$section_found" -eq 1 ]]; then
    if [[ "$entry_found" -eq 0 ]]; then
      printf '%s\n' "$desired_line" >> "$output_file"
      velocity_update_changed=1
      velocity_update_action="added"
    else
      velocity_update_action="updated"
    fi
  else
    if [[ -s "$source_file" ]]; then
      printf '\n' >> "$output_file"
    fi
    printf '[servers]\n' >> "$output_file"
    printf '%s\n' "$desired_line" >> "$output_file"
    velocity_update_changed=1
    velocity_update_action="created"
  fi

  if [[ "$velocity_update_changed" -eq 0 ]]; then
    velocity_update_action="unchanged"
  fi
}

update_velocity_config_file() {
  local velocity_server_json="$1"
  local server_key="$2"
  local target_ip="$3"
  local target_port="$4"
  local velocity_toml_path velocity_name_local endpoint
  local tmp_output

  velocity_name_local="$(printf '%s\n' "$velocity_server_json" | jq -r '.name')"
  velocity_toml_path="$(resolve_velocity_toml_path "$velocity_server_json")"
  endpoint="${target_ip}:${target_port}"

  if [[ ! -f "$velocity_toml_path" ]]; then
    printf '\nVelocity config update:\n'
    printf '  Velocity server: %s\n' "$velocity_name_local"
    printf '  Config path:     %s\n' "$velocity_toml_path"
    printf '  Result:          velocity.toml was not found.\n'
    printf '  Detail:          set PTERO_VELOCITY_TOML if Velocity stores its config elsewhere.\n'
    return 1
  fi

  tmp_output="$(mktemp)"
  trap 'rm -f "$tmp_output"' RETURN
  render_velocity_toml_update "$velocity_toml_path" "$tmp_output" "$server_key" "$endpoint"

  printf '\nVelocity config update:\n'
  printf '  Velocity server: %s\n' "$velocity_name_local"
  printf '  Config path:     %s\n' "$velocity_toml_path"
  printf '  Server key:      %s\n' "$server_key"
  printf '  Target:          %s\n' "$endpoint"

  if [[ "$dry_run" == "1" ]]; then
    printf '  Result:          dry run, preview only.\n'
    if [[ "$velocity_update_action" == "unchanged" ]]; then
      printf '  Detail:          no config change is needed.\n'
    else
      printf '  Detail:          would %s the matching [servers] entry.\n' "$velocity_update_action"
      diff -u "$velocity_toml_path" "$tmp_output" || true
    fi
    return 0
  fi

  if [[ "$velocity_update_action" == "unchanged" ]]; then
    printf '  Result:          no config change was needed.\n'
    return 0
  fi

  mv "$tmp_output" "$velocity_toml_path"
  trap - RETURN
  printf '  Result:          %s the matching [servers] entry.\n' "$velocity_update_action"
  printf '  Note:            restart Velocity for the config change to take effect.\n'
}

fetch_velocity_server_match() {
  local page=1
  local response total_pages matches_count matched

  if [[ -n "${PTERO_VELOCITY_SERVER:-}" ]]; then
    fetch_server_match "$PTERO_VELOCITY_SERVER"
    return $?
  fi

  while :; do
    response="$(ptero_api GET "/api/application/servers?include=allocations&per_page=100&page=${page}")"

    matched="$(
      printf '%s\n' "$response" \
        | jq -cs '
            map(
              .data[]
              | .attributes as $s
              | select(
                  (($s.external_id // "") | ascii_downcase | contains("velocity"))
                  or ($s.name | ascii_downcase | contains("velocity"))
                )
              | {
                  id: $s.id,
                  external_id: ($s.external_id // "-"),
                  uuid: $s.uuid,
                  identifier: (($s.uuid | split("-"))[0]),
                  name: $s.name,
                  allocations: (
                    $s.relationships.allocations.data // []
                    | map({
                        id: .attributes.id,
                        ip: .attributes.ip,
                        ip_alias: (.attributes.ip_alias // ""),
                        port: .attributes.port,
                        is_default: (.attributes.is_default // false)
                      })
                  )
                }
            )
            | add
          '
    )"

    if [[ -n "$matched" && "$matched" != "null" ]]; then
      matches+=("$matched")
    fi

    total_pages="$(printf '%s\n' "$response" | jq -r '.meta.pagination.total_pages // 1')"
    if [[ "$page" -ge "$total_pages" ]]; then
      break
    fi

    page=$((page + 1))
  done

  matches_count="${#matches[@]}"
  if [[ "$matches_count" -eq 1 ]]; then
    printf '%s\n' "${matches[0]}"
    return 0
  fi

  if [[ "$matches_count" -eq 0 ]]; then
    printf 'Could not auto-detect a Velocity Panel server. Set PTERO_VELOCITY_SERVER to a server ID, external ID, UUID, or exact name.\n' >&2
  else
    printf 'Auto-detected multiple Velocity-like Panel servers. Set PTERO_VELOCITY_SERVER to the intended server.\n' >&2
    printf '%s\n' "${matches[@]}" | jq -r '"  - ID \(.id): \(.name) [\(.external_id)]"' >&2
  fi

  return 1
}

check_backend_reachability() {
  local velocity_server_json="$1"
  local target_ip="$2"
  local target_port="$3"
  local target_label="${4:-target}"
  local velocity_uuid velocity_name_local velocity_container_name velocity_running
  local probe_result probe_detail

  velocity_uuid="$(printf '%s\n' "$velocity_server_json" | jq -r '.uuid')"
  velocity_name_local="$(printf '%s\n' "$velocity_server_json" | jq -r '.name')"
  last_reachability_status="failed"

  printf '\nReachability check:\n'
  printf '  Target label:    %s\n' "$target_label"
  printf '  Velocity server: %s (%s)\n' "$velocity_name_local" "$velocity_uuid"
  printf '  Target:          %s:%s\n' "$target_ip" "$target_port"

  if ! velocity_inspect_json="$(docker_inspect_json "$velocity_uuid")"; then
    printf '  Result:          could not inspect the Velocity container.\n'
    return 1
  fi

  velocity_container_name="$(printf '%s\n' "$velocity_inspect_json" | jq -r '.[0].Name // empty | ltrimstr("/")')"
  velocity_running="$(printf '%s\n' "$velocity_inspect_json" | jq -r '.[0].State.Running // false')"

  printf '  Container:       %s\n' "${velocity_container_name:-$velocity_uuid}"

  if [[ "$velocity_running" != "true" ]]; then
    last_reachability_status="inconclusive"
    printf '  Result:          Velocity container is not running.\n'
    return 1
  fi

  probe_result="$(capture_with_timeout 6 docker_exec_capture "$velocity_uuid" sh -lc '
if command -v nc >/dev/null 2>&1; then
  if nc -z -w 3 "$1" "$2"; then
    printf "reachable\tnc\n"
  else
    printf "failed\tnc\n"
  fi
elif command -v bash >/dev/null 2>&1; then
  if bash -lc "exec 3<>/dev/tcp/$1/$2"; then
    printf "reachable\tbash-dev-tcp\n"
  else
    printf "failed\tbash-dev-tcp\n"
  fi
else
  printf "unavailable\tnone\n"
fi
' sh "$target_ip" "$target_port" 2>/dev/null || true)"

  case "$probe_result" in
    $'reachable\tnc')
      last_reachability_status="reachable"
      printf '  Result:          reachable from Velocity container via netcat.\n'
      return 0
      ;;

    $'reachable\tbash-dev-tcp')
      last_reachability_status="reachable"
      printf '  Result:          reachable from Velocity container via bash /dev/tcp.\n'
      return 0
      ;;

    $'failed\tnc')
      last_reachability_status="failed"
      printf '  Result:          connection test failed from the Velocity container via netcat.\n'
      printf '  Detail:          could not connect to %s:%s from %s.\n' "$target_ip" "$target_port" "$velocity_name_local"
      return 1
      ;;

    $'failed\tbash-dev-tcp')
      last_reachability_status="failed"
      printf '  Result:          connection test failed from the Velocity container via bash /dev/tcp.\n'
      printf '  Detail:          could not connect to %s:%s from %s.\n' "$target_ip" "$target_port" "$velocity_name_local"
      return 1
      ;;

    $'unavailable\tnone')
      last_reachability_status="inconclusive"
      printf '  Result:          could not verify reachability from inside the Velocity container.\n'
      printf '  Detail:          neither netcat nor bash with /dev/tcp is available there.\n'
      return 1
      ;;

    '')
      last_reachability_status="inconclusive"
      printf '  Result:          could not verify reachability from inside the Velocity container.\n'
      printf '  Detail:          the probe timed out or returned no result.\n'
      return 1
      ;;

    *)
      last_reachability_status="inconclusive"
      probe_detail="${probe_result:-no probe result returned}"
      printf '  Result:          could not verify reachability from inside the Velocity container.\n'
      printf '  Detail:          probe execution was inconclusive: %s\n' "$probe_detail"
      return 1
      ;;
  esac
}

report_reachability_summary() {
  local selected_status="$1"
  local docker_status="${2:-}"

  printf '\nReachability summary:\n'
  printf '  Selected target: %s\n' "$selected_status"

  if [[ -n "$docker_status" ]]; then
    printf '  Docker target:   %s\n' "$docker_status"
  fi

  if [[ "$selected_status" == "reachable" ]]; then
    printf '  Recommendation:  current target mode looks usable.\n'
  elif [[ "$docker_status" == "reachable" ]]; then
    printf '  Recommendation:  rerun with --target-mode docker for this setup.\n'
  elif [[ "$selected_status" == "inconclusive" || "$docker_status" == "inconclusive" ]]; then
    printf '  Recommendation:  probe result was inconclusive; verify tooling or test manually from Velocity.\n'
  else
    printf '  Recommendation:  neither tested path was confirmed reachable from Velocity.\n'
  fi
}

fetch_server_match() {
  local query="$1"
  local page=1
  local response total_pages matched

  while :; do
    response="$(ptero_api GET "/api/application/servers?include=allocations&per_page=100&page=${page}")"

    matched="$(
      printf '%s\n' "$response" \
        | jq -c --arg query "$query" '
            .data[]
            | .attributes as $s
            | select(
                ($s.id | tostring) == $query
                or ($s.external_id // "") == $query
                or $s.uuid == $query
                or (($s.uuid | split("-"))[0]) == $query
                or $s.name == $query
              )
            | {
                id: $s.id,
                external_id: ($s.external_id // "-"),
                uuid: $s.uuid,
                identifier: (($s.uuid | split("-"))[0]),
                name: $s.name,
                allocations: (
                  $s.relationships.allocations.data // []
                  | map({
                      id: .attributes.id,
                      ip: .attributes.ip,
                      ip_alias: (.attributes.ip_alias // ""),
                      port: .attributes.port,
                      is_default: (.attributes.is_default // false)
                    })
                )
              }
          '
    )"

    if [[ -n "$matched" ]]; then
      printf '%s\n' "$matched"
      return 0
    fi

    total_pages="$(printf '%s\n' "$response" | jq -r '.meta.pagination.total_pages // 1')"
    if [[ "$page" -ge "$total_pages" ]]; then
      break
    fi

    page=$((page + 1))
  done

  return 1
}

require_tools
parse_args "$@"
matches=()
server_json="$(fetch_server_match "$server_query")" || {
  printf 'No Panel server matched: %s\n' "$server_query" >&2
  exit 1
}

uuid="$(printf '%s\n' "$server_json" | jq -r '.uuid')"
name="$(printf '%s\n' "$server_json" | jq -r '.name')"
external_id="$(printf '%s\n' "$server_json" | jq -r '.external_id')"
server_id="$(printf '%s\n' "$server_json" | jq -r '.id')"
identifier="$(printf '%s\n' "$server_json" | jq -r '.identifier')"

default_allocation="$(
  printf '%s\n' "$server_json" \
    | jq -c '
        (.allocations | map(select(.is_default == true)) | .[0])
        // (.allocations[0])
      '
)"

allocation_summary="$(
  printf '%s\n' "$server_json" \
    | jq -r '
        .allocations
        | map("\(.ip):\(.port)")
        | join(", ")
      '
)"

allocation_ip="$(printf '%s\n' "$default_allocation" | jq -r '.ip // empty')"
allocation_alias="$(printf '%s\n' "$default_allocation" | jq -r '.ip_alias // empty')"
allocation_port="$(printf '%s\n' "$default_allocation" | jq -r '.port // empty')"
allocation_id="$(printf '%s\n' "$default_allocation" | jq -r '.id // empty')"

server_key="$external_id"
if [[ -z "$server_key" || "$server_key" == "-" ]]; then
  server_key="$identifier"
fi

if [[ -n "$velocity_name" ]]; then
  server_key="$velocity_name"
fi

validate_server_key "$server_key" || exit 1

printf 'Panel server:\n'
printf '  ID:            %s\n' "$server_id"
printf '  External ID:   %s\n' "$external_id"
printf '  Name:          %s\n' "$name"
printf '  UUID:          %s\n' "$uuid"
printf '  Identifier:    %s\n' "$identifier"
printf '  Allocations:   %s\n' "$allocation_summary"

if [[ -n "$allocation_id" && -n "$allocation_ip" && -n "$allocation_port" ]]; then
  printf '  Default alloc: %s:%s (allocation %s)\n' "$allocation_ip" "$allocation_port" "$allocation_id"
  if [[ -n "$allocation_alias" ]]; then
    printf '  Alloc alias:    %s\n' "$allocation_alias"
  fi
fi

first_network_ip=""
if inspect_json="$(docker_inspect_json "$uuid")"; then
  container_name="$(printf '%s\n' "$inspect_json" | jq -r '.[0].Name // empty | ltrimstr("/")')"
  container_state="$(printf '%s\n' "$inspect_json" | jq -r '.[0].State.Status // empty')"
  container_running="$(printf '%s\n' "$inspect_json" | jq -r '.[0].State.Running // false')"
  networks_json="$(
    printf '%s\n' "$inspect_json" \
      | jq -c --arg port "$allocation_port" '
          (.[0].NetworkSettings.Networks // {})
          | with_entries(
              .value = {
                ip_address: (.value.IPAddress // ""),
                gateway: (.value.Gateway // ""),
                aliases: ((.value.Aliases // []) | map(select(. != null))),
                port: ($port | tonumber?)
              }
            )
        '
  )"

  printf '\nDocker container:\n'
  printf '  Name:          %s\n' "${container_name:-$uuid}"
  printf '  Running:       %s\n' "$container_running"
  printf '  State:         %s\n' "$container_state"

  mapfile -t network_rows < <(
    printf '%s\n' "$networks_json" \
      | jq -r '
          to_entries[]?
          | [
              .key,
              (.value.ip_address // "-"),
              (.value.gateway // "-"),
              ((.value.aliases // []) | join(","))
            ]
          | @tsv
        '
  )

  if [[ "${#network_rows[@]}" -gt 0 ]]; then
    printf '  Networks:\n'
    for row in "${network_rows[@]}"; do
      IFS=$'\t' read -r network_name network_ip network_gateway network_aliases <<< "$row"
      printf '    - %s\n' "$network_name"
      printf '      IP:      %s\n' "$network_ip"
      printf '      Gateway: %s\n' "$network_gateway"
      printf '      Aliases: %s\n' "${network_aliases:-none}"
    done
  fi

  if [[ "$container_running" != "true" ]]; then
    printf '  Note:          container is not running, so Docker may not have assigned a backend IP yet.\n'
  elif [[ -z "$(printf '%s\n' "$networks_json" | jq -r 'to_entries | map(.value.ip_address // "") | join("")')" ]]; then
    printf '  Note:          container is running, but no network IP was reported by Docker inspect.\n'
  fi

  first_network_ip="$(printf '%s\n' "$networks_json" | jq -r 'to_entries | map(.value.ip_address // "") | map(select(length > 0)) | .[0] // empty')"

  velocity_hint="$(velocity_hint_from_networks "$server_key" "$networks_json")"
  if [[ -n "$velocity_hint" ]]; then
    printf '\nDocker-network hint:\n'
    printf '  %s\n' "$velocity_hint"
  else
    printf '\nDocker-network hint:\n'
    printf '  No Docker-network IP is available yet for %s.\n' "$server_key"
  fi

else
  printf '\nDocker container:\n'
  printf '  Could not inspect container named %s.\n' "$uuid"
  printf '  This usually means Docker is unavailable here, sudo is required, or the container does not exist yet.\n'

  if [[ -n "$allocation_ip" && -n "$allocation_port" ]]; then
    printf '\nFallback hint:\n'
    printf '  %s = "%s:%s"\n' "$server_key" "$allocation_ip" "$allocation_port"
  fi

fi

allocation_target_host=""
if [[ -n "$allocation_alias" && "$allocation_alias" != "$allocation_ip" ]]; then
  allocation_target_host="$allocation_alias"
fi

resolve_backend_target "$allocation_target_host" "$allocation_ip" "$allocation_port" "$first_network_ip" || exit 1
print_backend_target

printf '\nVelocity hint:\n'
printf '  %s = "%s:%s"\n' "$server_key" "$resolved_target_host" "$resolved_target_port"

if [[ "$check_reachability" == "1" ]]; then
  if [[ "${container_running:-unknown}" != "true" ]]; then
    printf '\nReachability check:\n'
    printf '  Skipped: backend container is not running.\n'
    printf '  Hint:    start the backend once, then rerun ./ptero endpoint --check-reachability %s\n' "$server_query"
  else
    velocity_server_json="$(fetch_velocity_server_match)" || exit 1

    selected_reachability_status="failed"
    if check_backend_reachability "$velocity_server_json" "$resolved_target_host" "$resolved_target_port" "selected"; then
      selected_reachability_status="reachable"
    else
      selected_reachability_status="$last_reachability_status"
    fi

    docker_reachability_status=""
    if [[ -n "$first_network_ip" && ( "$first_network_ip" != "$resolved_target_host" || "$allocation_port" != "$resolved_target_port" ) ]]; then
      docker_reachability_status="failed"
      if check_backend_reachability "$velocity_server_json" "$first_network_ip" "$allocation_port" "docker-network"; then
        docker_reachability_status="reachable"
      else
        docker_reachability_status="$last_reachability_status"
      fi
    fi

    report_reachability_summary "$selected_reachability_status" "$docker_reachability_status"

    if [[ "$selected_reachability_status" != "reachable" ]]; then
      exit 1
    fi
  fi
fi

if [[ "$update_velocity_config" == "1" ]]; then
  if [[ -z "${velocity_server_json:-}" ]]; then
    velocity_server_json="$(fetch_velocity_server_match)" || exit 1
  fi
  update_velocity_config_file "$velocity_server_json" "$server_key" "$resolved_target_host" "$resolved_target_port" || exit 1
fi
