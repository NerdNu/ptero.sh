#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  ./plugins-toml-export <plugins-dir> [output-file]

Scans a NerdNu-style Minecraft server plugins directory and writes a simple
plugins.toml manifest.

Version detection rules:
- for symlinked jars, infer version from the resolved target path when possible
- for regular jars, infer version from the jar filename when possible
- otherwise use "latest"
USAGE
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

trim() {
  local value="$1"
  value="${value#${value%%[![:space:]]*}}"
  value="${value%${value##*[![:space:]]}}"
  printf '%s\n' "$value"
}

infer_from_symlink_target() {
  local target_path="$1"
  local parent_dir plugin_dir version name

  parent_dir="$(basename "$(dirname "$target_path")")"
  plugin_dir="$(basename "$(dirname "$(dirname "$target_path")")")"

  if [[ -n "$plugin_dir" && -n "$parent_dir" && "$plugin_dir" != "." && "$parent_dir" != "." ]]; then
    printf '%s\t%s\n' "$plugin_dir" "$parent_dir"
    return 0
  fi

  return 1
}

infer_from_filename() {
  local jar_name="$1"
  local stem name version

  stem="${jar_name%.jar}"

  if [[ "$stem" =~ ^(.+)-([0-9][A-Za-z0-9.+_-]*)$ ]]; then
    name="${BASH_REMATCH[1]}"
    version="${BASH_REMATCH[2]}"
    printf '%s\t%s\n' "$name" "$version"
    return 0
  fi

  printf '%s\tlatest\n' "$stem"
}

parse_args() {
  [[ $# -ge 1 && $# -le 2 ]] || {
    usage >&2
    exit 1
  }

  plugins_dir="$1"
  output_file="${2:-plugins.toml}"
}

main() {
  local plugins_dir output_file jar_path jar_name resolved_target inferred name version
  local -a jar_paths

  parse_args "$@"

  [[ -d "$plugins_dir" ]] || die "plugins directory does not exist: $plugins_dir"

  shopt -s nullglob
  jar_paths=("${plugins_dir%/}"/*.jar)
  shopt -u nullglob

  : > "$output_file"
  printf 'schema = 1\n' >> "$output_file"

  for jar_path in "${jar_paths[@]}"; do
    jar_name="$(basename "$jar_path")"
    name=""
    version="latest"

    if [[ -L "$jar_path" ]]; then
      resolved_target="$(readlink -f "$jar_path" 2>/dev/null || true)"
      if [[ -n "$resolved_target" ]]; then
        inferred="$(infer_from_symlink_target "$resolved_target" || true)"
        if [[ -n "$inferred" ]]; then
          IFS=$'\t' read -r name version <<< "$inferred"
        fi
      fi
    fi

    if [[ -z "$name" ]]; then
      inferred="$(infer_from_filename "$jar_name")"
      IFS=$'\t' read -r name version <<< "$inferred"
    fi

    name="$(trim "$name")"
    version="$(trim "$version")"

    printf '\n[[plugin]]\n' >> "$output_file"
    printf 'name = "%s"\n' "$name" >> "$output_file"
    printf 'jar = "%s"\n' "$jar_name" >> "$output_file"
    printf 'version = "%s"\n' "$version" >> "$output_file"
  done

  printf 'Wrote %s\n' "$output_file"
}

main "$@"
