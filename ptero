#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"

usage() {
  cat <<'USAGE'
Usage:
  ./ptero <command> [args...]

Read-only:
  ./ptero ping
  ./ptero users
  ./ptero allocations
  ./ptero servers
  ./ptero endpoint [--velocity-name <name>] [--target-host <host>] [--target-port <port>] [--check-reachability] [--update-velocity-config] <server>
  ./ptero endpoint <server>
  ./ptero forwarding-check <server>
  ./ptero egg [egg-id]

Write:
  ./ptero create <external-id> <display-name> <allocation-id> [server-type]
  ./ptero create-paper <external-id> <display-name> <allocation-id>
  ./ptero velocity-config-update <identifier>

Examples:
  ./ptero ping
  ./ptero allocations
  ./ptero servers
  ./ptero endpoint lobby-dev
  ./ptero endpoint --velocity-name lobby 10
  ./ptero endpoint --check-reachability --velocity-name lobby 10
  ./ptero endpoint --update-velocity-config --velocity-name lobby 10
  ./ptero forwarding-check lobby-dev
  ./ptero velocity-config-update lobby-dev
  ./ptero egg 1
  ./ptero create lobby-dev "Lobby Dev" 2
  ./ptero create lobby-dev "Lobby Dev" 2 paper
  ./ptero create modded-dev "Modded Dev" 7 fabric
  ./ptero create proxy-dev "Proxy Dev" 53 velocity
  PTERO_LIVE_RUN=1 ./ptero create lobby-dev "Lobby Dev" 2
USAGE
}

run_script() {
  local script="$1"
  shift

  if [[ ! -x "${SCRIPT_DIR}/${script}" ]]; then
    printf 'Missing or non-executable script: %s\n' "${SCRIPT_DIR}/${script}" >&2
    exit 1
  fi

  exec "${SCRIPT_DIR}/${script}" "$@"
}

if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

command="$1"
shift

case "$command" in
  ping)
    run_script ptero-ping "$@"
    ;;

  users|users-list)
    run_script ptero-users-list "$@"
    ;;

  allocations|allocations-list)
    run_script ptero-allocations-list "$@"
    ;;

  servers|servers-list)
    run_script ptero-servers-list "$@"
    ;;

  endpoint|endpoint-show)
    run_script ptero-endpoint-show "$@"
    ;;

  forwarding-check|forwarding)
    run_script ptero-forwarding-check "$@"
    ;;

  egg|egg-show)
    run_script ptero-egg-show "$@"
    ;;

  create|server-create)
    run_script ptero-server-create "$@"
    ;;

  create-paper|server-create-paper)
    run_script ptero-server-create-paper "$@"
    ;;

  velocity-config-update|velocity-update)
    run_script ptero-velocity-config-update "$@"
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    printf 'Unknown command: %s\n\n' "$command" >&2
    usage >&2
    exit 1
    ;;
esac
