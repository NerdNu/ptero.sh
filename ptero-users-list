#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
source "${SCRIPT_DIR}/ptero-common.sh"

page=1

printf '%-6s %-24s %-40s %s\n' "ID" "USERNAME" "EMAIL" "ADMIN"
printf '%-6s %-24s %-40s %s\n' "--" "--------" "-----" "-----"

while :; do
  response="$(ptero_api GET "/api/application/users?per_page=100&page=${page}")"

  printf '%s\n' "$response" \
    | jq -r '
        .data[]
        | [
            .attributes.id,
            .attributes.username,
            .attributes.email,
            .attributes.root_admin
          ]
        | @tsv
      ' \
    | while IFS=$'\t' read -r id username email admin; do
        printf '%-6s %-24s %-40s %s\n' "$id" "$username" "$email" "$admin"
      done

  total_pages="$(printf '%s\n' "$response" | jq -r '.meta.pagination.total_pages // 1')"

  if [[ "$page" -ge "$total_pages" ]]; then
    break
  fi

  page=$((page + 1))
done
