# Required
export PTERO_URL="https://panel-vex.nerd.nu"
export PTERO_APP_API_KEY="${PTERO_APP_API_KEY:-ptla_REPLACE_ME}"

# Your Panel user ID, not Linux UID 2001.
export PTERO_OWNER_ID="1"

# Your node ID. Your allocation command is currently using node 1.
export PTERO_NODE_ID="1"

# Default server type is paper
export PTERO_DEFAULT_SERVER_TYPE="${PTERO_DEFAULT_SERVER_TYPE:-paper}"

# Paper egg. You verified this is egg 1.
export PTERO_PAPER_EGG_ID="1"

# Where the docker volumes live.
export PTERO_VOLUMES_DIR="/docker/data/panel.nerd.nu/volumes"

# Optional override for velocity.toml updates.
# export PTERO_VELOCITY_TOML="/docker/data/panel.nerd.nu/volumes/<velocity-uuid>/velocity.toml"

# Optional backend target defaults for Velocity-oriented helpers.
# export PTERO_BACKEND_TARGET_MODE="allocation"
# export PTERO_BACKEND_TARGET_HOST="panel-node.example.net"
# export PTERO_BACKEND_TARGET_PORT="25565"

# Optional override when auto-detecting the Velocity server is ambiguous.
# export PTERO_VELOCITY_SERVER="proxy-dev"

# Defaults for Paper server creation.
export PTERO_DOCKER_IMAGE="ghcr.io/pterodactyl/yolks:java_21"
export PTERO_MEMORY_MIB="2048"
export PTERO_DISK_MIB="0"
export PTERO_CPU_PERCENT="0"
export PTERO_BACKUPS="3"
export PTERO_DATABASES="0"
export PTERO_EXTRA_ALLOCATIONS="0"

export PTERO_MINECRAFT_VERSION="latest"
export PTERO_SERVER_JARFILE="server.jar"
export PTERO_DL_PATH=""
export PTERO_BUILD_NUMBER="latest"

export PTERO_STARTUP='java -Xms128M -XX:MaxRAMPercentage=95.0 -Dterminal.jline=false -Dterminal.ansi=true -jar {{SERVER_JARFILE}}'

# Default to dry-run for write-oriented ptero commands.
# To live-run, unset PTERO_DRY_RUN in the shell before running the command.
export PTERO_DRY_RUN="${PTERO_DRY_RUN:-1}"
